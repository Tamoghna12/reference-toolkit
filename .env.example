# Reference Toolkit Environment Configuration
# Copy this file to .env and fill in your values

# Email address for API requests (REQUIRED)
# Most academic APIs require an email address for polite usage and rate limiting
# This email will be included in API requests as part of the User-Agent header
# Example: your-email@example.com
REFERENCETOOLKIT_EMAIL=your-email@example.com

# Optional: Proxy configuration for institutional access
# Uncomment and configure if you need to use a proxy server
#UNPAYWALL_PROXY_URL=http://proxy.institution.edu:8080
#UNPAYWALL_PROXY_USERNAME=your-username
#UNPAYWALL_PROXY_PASSWORD=your-password

# Optional: API keys for premium services
#SEMANTIC_SCHOLAR_API_KEY=your-api-key-here

# Optional: Default settings
#REFERENCETOOLKIT_SLEEP_TIME=0.5
#REFERENCETOOLKIT_TIMEOUT=30
#REFERENCETOOLKIT_MAX_RETRIES=3
